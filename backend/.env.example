# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
# Public base URL of THIS backend (used to build uploaded image URLs)
PUBLIC_URL=http://localhost:4000

# ─── MariaDB (Prisma uses the mysql provider, compatible with MariaDB) ───
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://erp:erp_password@localhost:3306/erp"

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────
# Generate strong secrets, e.g.  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ─── File uploads ────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# ─── KHQR / Bakong (Cambodia) ────────────────────────────
# Your Bakong account ID, e.g. "your_name@aclb" or a merchant ID like "your_company@trmc"
KHQR_BAKONG_ID=your_name@aclb
KHQR_MERCHANT_NAME=My ERP Store
KHQR_MERCHANT_CITY=PHNOM PENH
# Merchant Category Code (ISO 18245). 5999 = misc retail
KHQR_MCC=5999
# Bakong Open API — needed only to verify payment status server-side.
# Register at https://api-bakong.nbc.gov.kh to obtain a token.
BAKONG_API_URL=https://api-bakong.nbc.gov.kh
BAKONG_API_TOKEN=
