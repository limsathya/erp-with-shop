# ─── Database (MySQL / MariaDB) ──────────────────────
# Use a managed MySQL provider for Vercel (PlanetScale, Aiven, etc.)
DATABASE_URL="mysql://erp:erp_password@localhost:3306/erp"

# ─── Upstash Redis ───────────────────────────────────
# Get these from https://console.upstash.com (or Vercel Integrations → Redis)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Vercel Blob (file uploads) ───────────────────────
# Get these from https://vercel.com/dashboard/stores/blob
BLOB_READ_WRITE_TOKEN=

# ─── JWT ──────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ─── KHQR / Bakong (Cambodia) ─────────────────────────
KHQR_BAKONG_ID=your_name@aclb
KHQR_MERCHANT_NAME=My ERP Store
KHQR_MERCHANT_CITY=PHNOM PENH
KHQR_MCC=5999
BAKONG_API_URL=https://api-bakong.nbc.gov.kh
BAKONG_API_TOKEN=

# ─── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
